{
  "name": "ENKO AL Development",
  "dockerComposeFile": "docker-compose.yml",
  "service": "devcontainer",
  "workspaceFolder": "/workspace",

  // VS Code extensions installed automatically inside the container
  "customizations": {
    "vscode": {
      "extensions": [
        // AL Development
        "ms-dynamics-smb.al",

        // Claude Code
        "anthropic.claude-code",

        // Git & GitHub
        "github.vscode-pull-request-github",
        "eamodio.gitlens",

        // Code quality
        "streetsidesoftware.code-spell-checker",
        "editorconfig.editorconfig",

        // Markdown
        "yzhang.markdown-all-in-one",
        "davidanson.vscode-markdownlint",

        // YAML (for pipelines)
        "redhat.vscode-yaml",

        // PowerShell
        "ms-vscode.powershell"
      ],
      "settings": {
        // Editor
        "editor.formatOnSave": true,
        "editor.rulers": [120],
        "editor.tabSize": 4,
        "editor.insertSpaces": true,
        "files.trimTrailingWhitespace": true,
        "files.insertFinalNewline": true,

        // AL specific
        "al.enableCodeAnalysis": true,
        "al.backgroundCodeAnalysis": true,
        "al.codeAnalyzers": [
          "${CodeCop}",
          "${UICop}",
          "${PerTenantExtensionCop}"
        ],
        "al.packageCachePath": ".alpackages",

        // Terminal — default to PowerShell
        "terminal.integrated.defaultProfile.linux": "pwsh",
        "terminal.integrated.profiles.linux": {
          "pwsh": {
            "path": "/usr/bin/pwsh",
            "icon": "terminal-powershell"
          },
          "bash": {
            "path": "/bin/bash"
          }
        },

        // Git
        "git.autofetch": true,
        "git.confirmSync": false
      }
    }
  },

  // Ports to forward from container to host
  "forwardPorts": [],

  // Run after container is created
  "postCreateCommand": "bash .devcontainer/../scripts/install-al-tools.sh",

  // Run after container starts
  "postStartCommand": "pwsh /workspace/scripts/validate-launch-config.ps1 || true",

  // Container user
  "remoteUser": "vscode"
}
